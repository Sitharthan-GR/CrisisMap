# Application
APP_NAME=CrisisMap API
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Server (uvicorn)
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Supabase (required) — project URL ONLY (no /rest/v1 at the end)
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role secret from Dashboard → Project Settings → API (not anon/publishable)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: anon key if you later forward user JWTs from the frontend
# SUPABASE_ANON_KEY=your-anon-key

# Optional: override RPC name if your Supabase function differs
# SUPABASE_NEARBY_CRISIS_RPC=get_nearby_crisis_records
