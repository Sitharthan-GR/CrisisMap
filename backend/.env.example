# Application
APP_NAME=CrisisMap API
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Server (uvicorn)
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Supabase (required) — project URL ONLY (no /rest/v1 at the end)
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role secret from Dashboard → Project Settings → API (not anon/publishable)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: anon key if you later forward user JWTs from the frontend
# SUPABASE_ANON_KEY=your-anon-key

# Optional: what3words API key for w3w-based report locations
# WHAT3WORDS_API_KEY=your-w3w-api-key

# Supabase Storage bucket for report photos
# SUPABASE_STORAGE_BUCKET=rapida-photos

# Reverse geocoding (Nominatim) user agent — required by OSM usage policy
# NOMINATIM_USER_AGENT=CrisisMap/0.1 (your-contact@example.com)
