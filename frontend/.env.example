# API base URL (use Vite proxy in dev — leave as /api/v1)
VITE_API_URL=/api/v1

# Help page demo video (optional — see also public/demo-config.json for runtime URL)
#
# Direct MP4/WebM:
# VITE_DEMO_VIDEO_URL=https://your-project.supabase.co/storage/v1/object/public/videos/crisismap-demo.mp4
#
# YouTube (unlisted is fine):
# VITE_DEMO_VIDEO_URL=https://www.youtube.com/watch?v=YOUR_VIDEO_ID
#
# Vimeo:
# VITE_DEMO_VIDEO_URL=https://vimeo.com/123456789
#
# Local file during dev (copy demo/output/crisismap-full-demo.mp4 to frontend/public/):
# VITE_DEMO_VIDEO_URL=/crisismap-demo.mp4
